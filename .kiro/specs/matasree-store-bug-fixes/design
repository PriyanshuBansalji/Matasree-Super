#### Fix C6 — Analytics Payments: Structured Response Shape (Requirement 11)

**File:** `matasree-backend/src/controllers/adminController.ts`

The `getPaymentSummary` handler currently returns the raw aggregate array. Transform it into the expected structured object:

```typescript
export const getPaymentSummary = async (req: any, res: Response) => {
  try {
    const paymentSummary = await Payment.aggregate([
      {
        $group: {
          _id: '$method',
          total: { $sum: '$amount' },
          count: { $sum: 1 },
        },
      },
    ]);

    // Transform raw array into structured object
    const razorpayEntry = paymentSummary.find(p => p._id === 'razorpay');
    const codEntry      = paymentSummary.find(p => p._id === 'cod');

    const totalPayments   = paymentSummary.reduce((sum, p) => sum + p.count, 0);
    const razorpayPayments = razorpayEntry?.count ?? 0;
    const codPayments      = codEntry?.count      ?? 0;

    res.status(200).json(new ApiResponse(true, 'Payment summary fetched', {
      totalPayments,
      razorpayPayments,
      codPayments,
      paymentMethods: paymentSummary,
    }));
  } catch (error: any) {
    res.status(500).json(new ApiResponse(false, error.message || 'Failed to fetch payment summary', null, 500));
  }
};
```

